{
  "info": {
    "name": "Minimarket API — Pipeline Movimientos/Ventas (Fase 2)",
    "description": "Flujo end-to-end: registro -> login -> setup (2 almacenes + 1 tienda + 1 producto) -> movimientos (entrada, traspaso, casos de error) -> ventas (1 línea, multi-línea multi-origen, casos de error) -> reportes (historial de stock, más vendidos) -> bloqueo por permiso ausente (403 con el rol Lector).\n\nCorrer la colección completa en orden (Runner o Collection Runner). Depende de que la migración bd/migrations/007_add_movimientos_ventas.sql ya esté aplicada contra la base real. Cada carpeta depende de la anterior vía variables de colección (empresa_public_id, admin_email, admin_password, almacen_principal_id, almacen_secundario_id, tienda_id, producto_id, venta_id). La carpeta 06 cambia la cookie de sesión al usuario Lector y no la revierte -- es la última carpeta a propósito. Requiere la API corriendo en {{baseUrl}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "empresa_public_id", "value": "" },
    { "key": "admin_email", "value": "" },
    { "key": "admin_password", "value": "" },
    { "key": "almacen_principal_id", "value": "" },
    { "key": "almacen_secundario_id", "value": "" },
    { "key": "tienda_id", "value": "" },
    { "key": "producto_id", "value": "" },
    { "key": "venta_id", "value": "" },
    { "key": "rol_lector_id", "value": "" },
    { "key": "usuario_lector_id", "value": "" },
    { "key": "lector_email", "value": "" },
    { "key": "lector_password", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "1.1 POST /registro — crea empresa + admin nuevos",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "const ts = Date.now();",
                "pm.collectionVariables.set('admin_email', `admin.test.${ts}@minimarket.test`);",
                "pm.collectionVariables.set('admin_password', 'Admin1234!');",
                "pm.collectionVariables.set('empresa_ruc', `RUC${ts}`);"
              ] }
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.test('devuelve empresa_public_id', () => pm.expect(body.empresa_public_id).to.be.a('string'));",
                "pm.collectionVariables.set('empresa_public_id', body.empresa_public_id);"
              ] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empresa_nombre\": \"Empresa Test Movimientos Ventas\",\n  \"empresa_ruc\": \"{{empresa_ruc}}\",\n  \"admin_nombre\": \"Admin Test\",\n  \"admin_email\": \"{{admin_email}}\",\n  \"admin_password\": \"{{admin_password}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/registro", "host": ["{{baseUrl}}"], "path": ["registro"] }
          }
        },
        {
          "name": "1.2 POST /empresas/:id/auth/login",
          "event": [
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('ok: true', () => pm.expect(pm.response.json().ok).to.eql(true));",
                "pm.test('seteó la cookie httpOnly token', () => pm.expect(pm.cookies.has('token')).to.be.true);"
              ] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/empresas/{{empresa_public_id}}/auth/login", "host": ["{{baseUrl}}"], "path": ["empresas", "{{empresa_public_id}}", "auth", "login"] }
          }
        },
        {
          "name": "1.3 GET /empresas/:id/auth/me — confirma permisos de Fase 2",
          "event": [
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('tiene movimientos.create', () => pm.expect(body.permisos).to.include('movimientos.create'));",
                "pm.test('tiene movimientos.read', () => pm.expect(body.permisos).to.include('movimientos.read'));",
                "pm.test('tiene ventas.create', () => pm.expect(body.permisos).to.include('ventas.create'));",
                "pm.test('tiene ventas.read', () => pm.expect(body.permisos).to.include('ventas.read'));",
                "pm.test('tiene reportes.read', () => pm.expect(body.permisos).to.include('reportes.read'));"
              ] }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/empresas/{{empresa_public_id}}/auth/me", "host": ["{{baseUrl}}"], "path": ["empresas", "{{empresa_public_id}}", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "02 - Setup (almacenes, tienda, producto)",
      "item": [
        {
          "name": "2.1 POST /almacenes — Almacen Principal",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('almacen_principal_id', pm.response.json().public_id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Almacen Principal\",\n  \"ubicacion\": \"Lima\"\n}" },
            "url": { "raw": "{{baseUrl}}/almacenes", "host": ["{{baseUrl}}"], "path": ["almacenes"] }
          }
        },
        {
          "name": "2.2 POST /almacenes — Almacen Secundario (queda sin stock a propósito)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('almacen_secundario_id', pm.response.json().public_id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Almacen Secundario\",\n  \"ubicacion\": \"Callao\"\n}" },
            "url": { "raw": "{{baseUrl}}/almacenes", "host": ["{{baseUrl}}"], "path": ["almacenes"] }
          }
        },
        {
          "name": "2.3 POST /tiendas — Tienda Sur",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('tienda_id', pm.response.json().public_id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Tienda Sur\",\n  \"ubicacion\": \"Lima\"\n}" },
            "url": { "raw": "{{baseUrl}}/tiendas", "host": ["{{baseUrl}}"], "path": ["tiendas"] }
          }
        },
        {
          "name": "2.4 POST /productos — Producto Fase 2",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('producto_id', body.public_id);",
            "pm.test('precio_venta_unidad = 4.00', () => pm.expect(body.precio_venta_unidad).to.eql('4.00'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Producto Fase 2\",\n  \"precio_venta_unidad\": 4.00\n}" },
            "url": { "raw": "{{baseUrl}}/productos", "host": ["{{baseUrl}}"], "path": ["productos"] }
          }
        }
      ]
    },
    {
      "name": "03 - Movimientos",
      "item": [
        {
          "name": "3.1 POST /movimientos — entrada 100 en Almacen Principal",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('tipo entrada', () => pm.expect(body.tipo).to.eql('entrada'));",
            "pm.test('cantidad 100', () => pm.expect(body.cantidad).to.eql(100));",
            "pm.test('ubicacion_nombre correcto', () => pm.expect(body.ubicacion_nombre).to.eql('Almacen Principal'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"producto_id\": \"{{producto_id}}\",\n  \"tipo\": \"entrada\",\n  \"ubicacion_tipo\": \"almacen\",\n  \"ubicacion_id\": \"{{almacen_principal_id}}\",\n  \"cantidad\": 100,\n  \"motivo\": \"Compra inicial\"\n}" },
            "url": { "raw": "{{baseUrl}}/movimientos", "host": ["{{baseUrl}}"], "path": ["movimientos"] }
          }
        },
        {
          "name": "3.2 POST /movimientos — traspaso 30 Almacen Principal -> Tienda Sur",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('tipo traspaso', () => pm.expect(body.tipo).to.eql('traspaso'));",
            "pm.test('origen Almacen Principal', () => pm.expect(body.ubicacion_nombre).to.eql('Almacen Principal'));",
            "pm.test('destino Tienda Sur', () => pm.expect(body.ubicacion_destino_nombre).to.eql('Tienda Sur'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"producto_id\": \"{{producto_id}}\",\n  \"tipo\": \"traspaso\",\n  \"ubicacion_tipo\": \"almacen\",\n  \"ubicacion_id\": \"{{almacen_principal_id}}\",\n  \"ubicacion_destino_tipo\": \"tienda\",\n  \"ubicacion_destino_id\": \"{{tienda_id}}\",\n  \"cantidad\": 30\n}" },
            "url": { "raw": "{{baseUrl}}/movimientos", "host": ["{{baseUrl}}"], "path": ["movimientos"] }
          }
        },
        {
          "name": "3.3 GET /productos/:id/stock — confirma 70 en almacen y 30 en tienda",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('almacen principal en 70', () => pm.expect(body.almacenes[0].stock_actual).to.eql(70));",
            "pm.test('tienda sur en 30', () => pm.expect(body.tiendas[0].stock_actual).to.eql(30));"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/productos/{{producto_id}}/stock", "host": ["{{baseUrl}}"], "path": ["productos", "{{producto_id}}", "stock"] } }
        },
        {
          "name": "3.4 GET /movimientos — listado, 2 registrados",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('2 movimientos', () => pm.expect(pm.response.json().data).to.have.lengthOf(2));"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/movimientos", "host": ["{{baseUrl}}"], "path": ["movimientos"] } }
        },
        {
          "name": "3.5 POST /movimientos — tipo inválido (debe rechazar, 400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
            "pm.test('menciona tipo', () => pm.expect(pm.response.json().error).to.include('tipo'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"producto_id\": \"{{producto_id}}\",\n  \"tipo\": \"invento\",\n  \"ubicacion_tipo\": \"almacen\",\n  \"ubicacion_id\": \"{{almacen_principal_id}}\",\n  \"cantidad\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/movimientos", "host": ["{{baseUrl}}"], "path": ["movimientos"] }
          }
        },
        {
          "name": "3.6 POST /movimientos — traspaso sin ubicacion_destino_id (debe rechazar, 400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
            "pm.test('menciona ubicacion_destino_id', () => pm.expect(pm.response.json().error).to.include('ubicacion_destino_id'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"producto_id\": \"{{producto_id}}\",\n  \"tipo\": \"traspaso\",\n  \"ubicacion_tipo\": \"almacen\",\n  \"ubicacion_id\": \"{{almacen_principal_id}}\",\n  \"ubicacion_destino_tipo\": \"tienda\",\n  \"cantidad\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/movimientos", "host": ["{{baseUrl}}"], "path": ["movimientos"] }
          }
        },
        {
          "name": "3.7 POST /movimientos — salida desde Almacen Secundario sin stock previo (debe rechazar, 409)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('409 Conflict', () => pm.response.to.have.status(409));",
            "pm.test('mensaje menciona stock', () => pm.expect(pm.response.json().error.toLowerCase()).to.include('stock'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"producto_id\": \"{{producto_id}}\",\n  \"tipo\": \"salida\",\n  \"ubicacion_tipo\": \"almacen\",\n  \"ubicacion_id\": \"{{almacen_secundario_id}}\",\n  \"cantidad\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/movimientos", "host": ["{{baseUrl}}"], "path": ["movimientos"] }
          }
        }
      ]
    },
    {
      "name": "04 - Ventas",
      "item": [
        {
          "name": "4.1 POST /ventas — 1 línea desde Tienda Sur (5 unidades)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('venta_id', body.public_id);",
            "pm.test('total = 20.00', () => pm.expect(body.total).to.eql('20.00'));",
            "pm.test('1 linea en el detalle', () => pm.expect(body.detalle).to.have.lengthOf(1));",
            "pm.test('subtotal de la linea = 20.00', () => pm.expect(body.detalle[0].subtotal).to.eql('20.00'));",
            "pm.test('precio_unitario snapshot = 4.00', () => pm.expect(body.detalle[0].precio_unitario).to.eql('4.00'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tienda_id\": \"{{tienda_id}}\",\n  \"lineas\": [\n    { \"producto_id\": \"{{producto_id}}\", \"cantidad\": 5, \"origen_tipo\": \"tienda\", \"origen_id\": \"{{tienda_id}}\" }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/ventas", "host": ["{{baseUrl}}"], "path": ["ventas"] }
          }
        },
        {
          "name": "4.2 GET /ventas/:id — detalle",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('public_id coincide', () => pm.expect(body.public_id).to.eql(pm.collectionVariables.get('venta_id')));",
            "pm.test('creado_por_nombre presente', () => pm.expect(body.creado_por_nombre).to.eql('Admin Test'));"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/ventas/{{venta_id}}", "host": ["{{baseUrl}}"], "path": ["ventas", "{{venta_id}}"] } }
        },
        {
          "name": "4.3 GET /ventas — listado",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('incluye la venta creada', () => pm.expect(body.data.some(v => v.public_id === pm.collectionVariables.get('venta_id'))).to.be.true);"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/ventas", "host": ["{{baseUrl}}"], "path": ["ventas"] } }
        },
        {
          "name": "4.4 POST /ventas — 2 líneas, orígenes distintos (regla: el cajero elige el origen por línea)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('total = 52.00 (3x4.00 desde tienda + 10x4.00 desde almacen)', () => pm.expect(body.total).to.eql('52.00'));",
            "pm.test('2 lineas en el detalle', () => pm.expect(body.detalle).to.have.lengthOf(2));",
            "pm.test('linea 1 origen tienda', () => pm.expect(body.detalle[0].origen_tipo).to.eql('tienda'));",
            "pm.test('linea 2 origen almacen', () => pm.expect(body.detalle[1].origen_tipo).to.eql('almacen'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tienda_id\": \"{{tienda_id}}\",\n  \"lineas\": [\n    { \"producto_id\": \"{{producto_id}}\", \"cantidad\": 3, \"origen_tipo\": \"tienda\", \"origen_id\": \"{{tienda_id}}\" },\n    { \"producto_id\": \"{{producto_id}}\", \"cantidad\": 10, \"origen_tipo\": \"almacen\", \"origen_id\": \"{{almacen_principal_id}}\" }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/ventas", "host": ["{{baseUrl}}"], "path": ["ventas"] }
          }
        },
        {
          "name": "4.5 POST /ventas — cantidad mayor al stock disponible (debe rechazar, 400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
            "pm.test('mensaje legible, sin nombre de constraint interno', () => {",
            "  const msg = pm.response.json().error;",
            "  pm.expect(msg).to.include('stock suficiente');",
            "  pm.expect(msg).to.not.include('chk_');",
            "});"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tienda_id\": \"{{tienda_id}}\",\n  \"lineas\": [\n    { \"producto_id\": \"{{producto_id}}\", \"cantidad\": 9999, \"origen_tipo\": \"tienda\", \"origen_id\": \"{{tienda_id}}\" }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/ventas", "host": ["{{baseUrl}}"], "path": ["ventas"] }
          }
        },
        {
          "name": "4.6 POST /ventas — sin lineas (debe rechazar, 400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
            "pm.test('menciona al menos una linea', () => pm.expect(pm.response.json().error).to.include('linea'));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tienda_id\": \"{{tienda_id}}\",\n  \"lineas\": []\n}" },
            "url": { "raw": "{{baseUrl}}/ventas", "host": ["{{baseUrl}}"], "path": ["ventas"] }
          }
        },
        {
          "name": "4.7 GET /productos/:id/stock — confirma stock final (60 almacen, 22 tienda)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('almacen principal en 60', () => pm.expect(body.almacenes[0].stock_actual).to.eql(60));",
            "pm.test('tienda sur en 22', () => pm.expect(body.tiendas[0].stock_actual).to.eql(22));"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/productos/{{producto_id}}/stock", "host": ["{{baseUrl}}"], "path": ["productos", "{{producto_id}}", "stock"] } }
        }
      ]
    },
    {
      "name": "05 - Reportes",
      "item": [
        {
          "name": "5.1 GET /reportes/historial-stock/:productoId — 4 salidas (traspaso + 2 ventas, sin la entrada)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('4 filas', () => pm.expect(body.data).to.have.lengthOf(4));",
            "pm.test('ninguna fila es de tipo entrada', () => pm.expect(body.data.every(f => f.tipo !== 'entrada')).to.be.true);",
            "pm.test('hay 1 traspaso y 3 ventas', () => {",
            "  const tipos = body.data.map(f => f.tipo);",
            "  pm.expect(tipos.filter(t => t === 'salida')).to.have.lengthOf(1);",
            "  pm.expect(tipos.filter(t => t === 'venta')).to.have.lengthOf(3);",
            "});"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/reportes/historial-stock/{{producto_id}}", "host": ["{{baseUrl}}"], "path": ["reportes", "historial-stock", "{{producto_id}}"] } }
        },
        {
          "name": "5.2 GET /reportes/mas-vendidos — Producto Fase 2 con 18 unidades vendidas",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "const fila = body.data.find(f => f.producto_public_id === pm.collectionVariables.get('producto_id'));",
